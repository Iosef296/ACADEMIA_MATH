# Copy to .env and fill in values before running docker-compose

# PostgreSQL (docker-compose)
POSTGRES_DB=academia_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# Backend (Spring Boot)
DATABASE_URL=jdbc:postgresql://localhost:5435/academia_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=change_me_in_production

# JWT — minimum 32 chars, use a random secret in production
JWT_SECRET=change_me_to_a_random_32_plus_char_secret
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Server
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Flyway — set to validate in production
FLYWAY_ENABLED=true
JPA_DDL_AUTO=update
